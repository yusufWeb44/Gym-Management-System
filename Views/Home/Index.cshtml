@model GymManagementSystem.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Home Page";
}
 
<div class="hero-section">
    <div class="container">
        <h1><i class="fas fa-dumbbell me-3"></i>GYM Management System</h1>
        <p>Manage your gym professionally</p>
    </div>
</div>

<div class="container">
    <!-- Statistics -->
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card members animate-fade-in">
                <div class="icon"><i class="fas fa-users"></i></div>
                <div class="number">@Model.TotalMembers</div>
                <div class="label">Total Members</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card trainers animate-fade-in" style="animation-delay: 0.1s;">
                <div class="icon"><i class="fas fa-user-tie"></i></div>
                <div class="number">@Model.TotalTrainers</div>
                <div class="label">Trainers</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card plans animate-fade-in" style="animation-delay: 0.2s;">
                <div class="icon"><i class="fas fa-clipboard-list"></i></div>
                <div class="number">@Model.TotalPlans</div>
                <div class="label">Active Plans</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card fitness animate-fade-in" style="animation-delay: 0.3s;">
                <div class="icon"><i class="fas fa-heartbeat"></i></div>
                <div class="number">@Model.TotalFitnessTypes</div>
                <div class="label">Fitness Types</div>
            </div>
        </div>
    </div>

    <!-- Today Stats -->
    <div class="d-flex align-items-center gap-2 mb-4 mt-5">
        <h4 class="mb-0 text-white"><i class="fas fa-calendar-day text-primary me-2"></i>Today's Status</h4>
    </div>
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card info animate-fade-in" style="animation-delay: 0.3s;">
                <div class="icon"><i class="fas fa-users-cog"></i></div>
                <div class="number">@Model.TodayStats.ActiveMembers</div>
                <div class="label">Active Members</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card members animate-fade-in">
                <div class="icon"><i class="fas fa-user-plus"></i></div>
                <div class="number">@Model.TodayStats.NewMembersToday</div>
                <div class="label">New Registrations</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card trainers animate-fade-in" style="animation-delay: 0.1s;">
                <div class="icon"><i class="fas fa-play-circle"></i></div>
                <div class="number">@Model.TodayStats.StartedMembershipsToday</div>
                <div class="label">Started Memberships</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card danger animate-fade-in" style="animation-delay: 0.2s;">
                <div class="icon"><i class="fas fa-times-circle"></i></div>
                <div class="number">@Model.TodayStats.ExpiredMembershipsToday</div>
                <div class="label">Expired Memberships</div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    <div class="d-flex align-items-center gap-2 mb-4">
        <h4 class="mb-0 text-white"><i class="fas fa-bell text-warning me-2"></i>Subscription Alerts</h4>
    </div>
    <div class="row mb-5">
        <!-- Expiring Soon Alerts -->
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow-sm animate-fade-in" style="border-top: 4px solid #f2c94c;">
                <div class="card-header border-0 bg-transparent pt-4 pb-2">
                    <h5 class="mb-0" style="color: #f2c94c; font-weight: 600;"><i class="fas fa-exclamation-triangle me-2"></i>Memberships Expiring Soon</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" style="background: transparent;">
                        @if(!Model.ExpiringMembers.Any())
                        {
                            <li class="list-group-item text-muted text-center py-4" style="background: transparent; border-color: rgba(255,255,255,0.05);">
                                <i class="fas fa-check-circle me-2 text-success"></i>No memberships expiring soon.
                            </li>
                        }
                        @foreach(var member in Model.ExpiringMembers)
                        {
                            <li class="list-group-item text-white d-flex justify-content-between align-items-center py-3" style="background: transparent; border-color: rgba(255,255,255,0.05);">
                                <div>
                                    <h6 class="mb-1" style="font-weight: 500;">@member.FullName</h6>
                                    <small class="text-muted"><i class="fas fa-clipboard-list me-1 opacity-75"></i>@(member.Plan?.Name ?? "No Plan") <span class="mx-2 opacity-50">|</span> <i class="fas fa-user-tie me-1 opacity-75"></i>@(member.Trainer?.FullName ?? "No Trainer")</small>
                                </div>
                                <span class="badge rounded-pill px-3 py-2" style="background: rgba(242, 201, 76, 0.15); color: #f2c94c; font-weight: 500; font-size: 0.85rem; border: 1px solid rgba(242, 201, 76, 0.3);">
                                    <i class="far fa-clock me-1"></i>@member.RemainingDays Days Left
                                </span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Expired Alerts -->
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow-sm animate-fade-in" style="border-top: 4px solid #f45c43;">
                <div class="card-header border-0 bg-transparent pt-4 pb-2">
                    <h5 class="mb-0" style="color: #f45c43; font-weight: 600;"><i class="fas fa-exclamation-circle me-2"></i>Expired Memberships</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" style="background: transparent;">
                        @if(!Model.ExpiredMembers.Any())
                        {
                            <li class="list-group-item text-muted text-center py-4" style="background: transparent; border-color: rgba(255,255,255,0.05);">
                                <i class="fas fa-check-circle me-2 text-success"></i>No expired memberships.
                            </li>
                        }
                        @foreach(var member in Model.ExpiredMembers)
                        {
                            <li class="list-group-item text-white d-flex justify-content-between align-items-center py-3" style="background: transparent; border-color: rgba(255,255,255,0.05);">
                                <div>
                                    <h6 class="mb-1" style="font-weight: 500;">@member.FullName</h6>
                                    <small class="text-muted"><i class="fas fa-clipboard-list me-1 opacity-75"></i>@(member.Plan?.Name ?? "No Plan") <span class="mx-2 opacity-50">|</span> <i class="fas fa-user-tie me-1 opacity-75"></i>@(member.Trainer?.FullName ?? "No Trainer")</small>
                                </div>
                                <span class="badge rounded-pill px-3 py-2" style="background: rgba(244, 92, 67, 0.15); color: #f45c43; font-weight: 500; font-size: 0.85rem; border: 1px solid rgba(244, 92, 67, 0.3);">
                                    <i class="fas fa-ban me-1"></i>Expired
                                </span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <!-- Quick Actions -->
        <div class="col-lg-5 mb-4">
            <div class="card h-100 shadow-sm animate-fade-in">
                <div class="card-header border-0 bg-transparent pt-4 pb-2">
                    <h5 class="mb-0"><i class="fas fa-bolt text-warning me-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-3">
                        <a asp-controller="Members" asp-action="Create" class="btn btn-primary">
                            <i class="fas fa-user-plus me-2"></i>Add New Member
                        </a>
                        <a asp-controller="Trainers" asp-action="Create" class="btn btn-success">
                            <i class="fas fa-user-tie me-2"></i>Add New Trainer
                        </a>
                        <a asp-controller="Plans" asp-action="Create" class="btn btn-warning">
                            <i class="fas fa-clipboard-list me-2"></i>Create New Plan
                        </a>
                        <a asp-controller="FitnessTypes" asp-action="Create" class="btn btn-secondary">
                            <i class="fas fa-heartbeat me-2"></i>Add Fitness Type
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Trainer Workload Chart -->
        <div class="col-lg-7 mb-4">
            <div class="card h-100 shadow-sm animate-fade-in" style="animation-delay: 0.1s;">
                <div class="card-header border-0 bg-transparent pt-4 pb-2 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-info"><i class="fas fa-chart-bar me-2"></i>Trainer Workload</h5>
                </div>
                <div class="card-body d-flex flex-column">
                    <div style="flex-grow: 1; min-height: 250px; position: relative;">
                        <canvas id="trainerLoadChart"></canvas>
                    </div>
                    <div id="chartInsight" class="mt-3 text-center small text-muted" style="min-height: 24px;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly Registrations Chart -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm animate-fade-in" style="animation-delay: 0.2s;">
                <div class="card-header border-0 bg-transparent pt-4 pb-2">
                    <h5 class="mb-0 text-primary"><i class="fas fa-chart-line me-2"></i>Monthly Registrations</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px; position: relative;">
                        <canvas id="monthlyMembersChart"></canvas>
                    </div>
                    <div id="monthlyInsight" class="mt-3 text-center small text-muted" style="min-height: 24px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- Trainer Workload Chart ---
            const trainerNames = @Html.Raw(Json.Serialize(Model.TrainerNames));
            const memberCounts = @Html.Raw(Json.Serialize(Model.TrainerMemberCounts));

            const ctxTrainer = document.getElementById('trainerLoadChart').getContext('2d');
            
            let gradientTrainer = ctxTrainer.createLinearGradient(0, 0, 0, 400);
            gradientTrainer.addColorStop(0, 'rgba(54, 162, 235, 0.8)');
            gradientTrainer.addColorStop(1, 'rgba(54, 162, 235, 0.2)');

            new Chart(ctxTrainer, {
                type: 'bar',
                data: {
                    labels: trainerNames,
                    datasets: [{
                        label: 'Member Count',
                        data: memberCounts,
                        backgroundColor: gradientTrainer,
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1,
                        borderRadius: 6,
                        hoverBackgroundColor: 'rgba(54, 162, 235, 1)'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0, color: '#aaa' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                        x: { ticks: { color: '#aaa' }, grid: { display: false } }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: 'rgba(0,0,0,0.8)', padding: 10 }
                    }
                }
            });

            // Trainer Insight
            if (memberCounts.length > 0) {
                const maxMembers = Math.max(...memberCounts);
                const minMembers = Math.min(...memberCounts);
                const maxIndex = memberCounts.indexOf(maxMembers);
                const maxTrainerName = trainerNames[maxIndex];

                const insightDiv = document.getElementById('chartInsight');
                
                if (maxMembers === 0) {
                    insightDiv.innerHTML = "💡 No members assigned to any trainer yet.";
                } else if (maxMembers - minMembers > 5) {
                    insightDiv.innerHTML = `<span class="text-warning"><i class="fas fa-exclamation-triangle"></i> <b>${maxTrainerName}</b> has the highest load (${maxMembers} members). Consider balancing the workload.</span>`;
                } else {
                    insightDiv.innerHTML = `<span class="text-success"><i class="fas fa-check-circle"></i> Trainer workload appears balanced!</span>`;
                }
            }

            // --- Monthly Registrations Chart ---
            const monthlyLabels = @Html.Raw(Json.Serialize(Model.MonthlyLabels));
            const monthlyCounts = @Html.Raw(Json.Serialize(Model.MonthlyCounts));

            const ctxMonthly = document.getElementById('monthlyMembersChart').getContext('2d');
            
            let gradientMonthly = ctxMonthly.createLinearGradient(0, 0, 0, 300);
            gradientMonthly.addColorStop(0, 'rgba(0, 210, 255, 0.3)');
            gradientMonthly.addColorStop(1, 'rgba(0, 210, 255, 0)');

            new Chart(ctxMonthly, {
                type: 'line',
                data: {
                    labels: monthlyLabels,
                    datasets: [{
                        label: 'Yeni Kayıtlar',
                        data: monthlyCounts,
                        fill: true,
                        backgroundColor: gradientMonthly,
                        borderColor: '#00d2ff',
                        borderWidth: 3,
                        pointBackgroundColor: '#00d2ff',
                        pointBorderColor: '#fff',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: '#00d2ff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            ticks: { precision: 0, color: '#aaa' }, 
                            grid: { color: 'rgba(255,255,255,0.05)' } 
                        },
                        x: { 
                            ticks: { color: '#aaa' }, 
                            grid: { display: false } 
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: 'rgba(0,0,0,0.8)', padding: 10 }
                    }
                }
            });

            // Monthly Insight Logic
            if (monthlyCounts.length >= 2) {
                const lastMonth = monthlyCounts[monthlyCounts.length - 1];
                const prevMonth = monthlyCounts[monthlyCounts.length - 2];
                const monthlyInsightDiv = document.getElementById('monthlyInsight');

                if (lastMonth > prevMonth) {
                    monthlyInsightDiv.innerHTML = `<span class="text-success"><i class="fas fa-arrow-up me-1"></i> Member registrations are increasing compared to last month!</span>`;
                } else if (lastMonth < prevMonth) {
                    monthlyInsightDiv.innerHTML = `<span class="text-warning"><i class="fas fa-arrow-down me-1"></i> Registrations this month are slightly lower than last month.</span>`;
                } else {
                    monthlyInsightDiv.innerHTML = `<span class="text-info"><i class="fas fa-minus me-1"></i> Registration rate is stable at the same level as last month.</span>`;
                }
            }
        });
    </script>
}

