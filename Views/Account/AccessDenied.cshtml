@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
 
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GYM Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .access-denied-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--dark-bg);
        }

        .access-denied-card {
            background: rgba(22, 33, 62, 0.9);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(235, 51, 73, 0.2);
            border-radius: 20px;
            padding: 3rem;
            text-align: center;
            max-width: 460px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.6s ease forwards;
        }

        .access-denied-card .icon {
            font-size: 4rem;
            background: var(--danger-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1.5rem;
        }

        .access-denied-card h2 {
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .access-denied-card p {
            color: var(--text-muted);
            margin-bottom: 2rem;
        }
    </style>
</head>
<body>
    <div class="access-denied-page">
        <div class="access-denied-card">
            <div class="icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h2>Access Denied</h2>
            <p>You do not have permission to access this page.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                <i class="fas fa-sign-in-alt me-2"></i>Return to Login
            </a>
        </div>
    </div>
</body>
</html>
