@model IEnumerable<GymManagementSystem.Models.FitnessType>
@{
    ViewData["Title"] = "Fitness Types";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-heartbeat me-3"></i>Fitness Types</h1>
        <p>Manage fitness categories in the gym</p>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>All Fitness Types</h4>
        
        <div class="position-relative mx-3 flex-grow-1" style="max-width: 400px;">
            <i class="fas fa-search position-absolute text-muted" style="left: 16px; top: 50%; transform: translateY(-50%);"></i>
            <input type="text" id="pageSearchInput" class="form-control shadow-sm" placeholder="Quick search..." autocomplete="off" style="border-radius: 10px; padding-left: 45px; padding-top: 10px; padding-bottom: 10px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); color: #fff; transition: all 0.3s ease;" onfocus="this.style.background='rgba(255,255,255,0.08)'; this.style.borderColor='rgba(255,255,255,0.3)';">
        </div>
 
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Fitness Type
        </a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="fitness-card card h-100">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" />
                    }
                    else
                    {
                        <div style="height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-dumbbell fa-4x text-white"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="text-white">@item.Name</h5>
                        <p class="text-white-50 small mb-3">
                            @(item.Description?.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description)
                        </p>
                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-heartbeat fa-4x text-muted mb-3"></i>
                <h5>No fitness types added yet</h5>
                <p class="text-muted">Click the button above to add your first fitness type.</p>
            </div>
        </div>
    }
</div>
