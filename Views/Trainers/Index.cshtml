@model IEnumerable<GymManagementSystem.Models.Trainer>
@{
    ViewData["Title"] = "Trainers";
}

<div class="page-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
    <div class="container">
        <h1><i class="fas fa-user-tie me-3"></i>Trainers</h1>
        <p>Manage gym trainers</p>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>All Trainers</h4>
        
        <div class="position-relative mx-3 flex-grow-1" style="max-width: 400px;">
            <i class="fas fa-search position-absolute text-muted" style="left: 16px; top: 50%; transform: translateY(-50%);"></i>
            <input type="text" id="pageSearchInput" class="form-control shadow-sm" placeholder="Quick search..." autocomplete="off" style="border-radius: 10px; padding-left: 45px; padding-top: 10px; padding-bottom: 10px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); color: #fff; transition: all 0.3s ease;" onfocus="this.style.background='rgba(255,255,255,0.08)'; this.style.borderColor='rgba(255,255,255,0.3)';">
        </div>
 
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>New Trainer
        </a>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Specialization</th>
                            <th>Experience</th>
                            <th>Salary</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.FullName" class="member-photo" />
                                    }
                                    else
                                    {
                                        <div class="member-photo bg-secondary d-flex align-items-center justify-content-center">
                                            <i class="fas fa-user-tie text-white"></i>
                                        </div>
                                    }
                                </td>
                                <td><strong>@item.FullName</strong></td>
                                <td>@item.Email</td>
                                <td>@item.Phone</td>
                                <td>
                                    @foreach (var fitType in item.FitnessTypes)
                                    {
                                        <span class="badge bg-primary me-1 mb-1">@fitType.Name</span>
                                    }
                                </td>
                                <td>@item.ExperienceYears years</td>
                                <td>@item.Salary.ToString("C0", new System.Globalization.CultureInfo("en-US"))</td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card mt-4">
            <div class="card-body text-center py-5">
                <i class="fas fa-user-tie fa-4x text-muted mb-3"></i>
                <h5>No trainers added yet</h5>
                <p class="text-muted">Click the button above to add your first trainer.</p>
            </div>
        </div>
    }
</div>
